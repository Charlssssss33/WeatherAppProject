<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ChrnProjectP511.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ChrnProjectP511.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ChrnProjectP511">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    
  

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">
        <!-- Отступ сверху -->
        <Rectangle Grid.Row="0" Height="20"/>

        <!-- Заголовок -->
        <Border Grid.Row="1" Margin="20,0">
            <TextBlock Text="🌦️ Weather App"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#F8FAFC"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" Spacing="15">

                <!-- Поле ввода -->
                <Border Background="#1E293B"
                        CornerRadius="12"
                        Padding="12">
                    <TextBox x:Name="CityInput"
                             Text="{Binding CityName}"
                             Watermark="🏙️ Введите город (например, Moscow)"
                             Foreground="#F8FAFC"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="16"/>
                </Border>

                <!-- Кнопки -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Grid.Column="0"
                            Command="{Binding SearchWeatherCommand}"
                            Content="🔍 Погода"
                            Background="#3B82F6"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="12"
                            CornerRadius="10"
                            FontSize="14"/>
                    
                    <Button Grid.Column="1"
                            Command="{Binding SaveDefaultCityCommand}"
                            Content="⭐ Запомнить"
                            Background="#8B5CF6"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="12"
                            CornerRadius="10"
                            FontSize="14"/>
                </Grid>

                <!-- Загрузка -->
                <TextBlock Text="⏳ Загрузка погоды..."
                           Foreground="#94A3B8"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding IsLoading}"
                           FontSize="13"/>

                <!-- Ошибка -->
                <TextBlock Text="{Binding ErrorText}"
                           Foreground="#EF4444"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding IsErrorVisible}"
                           FontSize="13"
                           FontWeight="Bold"/>

                <!-- Карточка погоды -->
                <Border IsVisible="{Binding IsWeatherCardVisible}"
        Background="#1E293B"
        CornerRadius="20"
        Padding="20">

    <StackPanel Spacing="12">
        <TextBlock Text="{Binding CityNameText}" />     
        <TextBlock Text="{Binding IconText}" />         
        <TextBlock Text="{Binding TempText}" />         
        <TextBlock Text="{Binding DescriptionText}" />  
        <TextBlock Text="{Binding WindText}" />         
        <TextBlock Text="{Binding HumidityText}" />    
    </StackPanel>
</Border>

                        <!-- Город -->
                        <TextBlock Text="{Binding CityNameText}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Center"/>

                        <!-- Температура + иконка -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <TextBlock Text="{Binding IconText}"
                                       FontSize="56"
                                       Foreground="#FBBF24"/>
                            <TextBlock Text="{Binding TempText}"
                                       FontSize="56"
                                       FontWeight="Bold"
                                       Foreground="#F8FAFC"/>
                        </StackPanel>

                        <!-- Описание -->
                        <TextBlock Text="{Binding DescriptionText}"
                                   FontSize="16"
                                   Foreground="#94A3B8"
                                   HorizontalAlignment="Center"/>

                        <!-- Разделитель -->
                        <Border Height="1"
                                Background="#334155"
                                Margin="0,5"/>

                        <!-- Дополнительно -->
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0"
                                        HorizontalAlignment="Center"
                                        Spacing="4">
                                <TextBlock Text="💨 Ветер"
                                           Foreground="#64748B"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding WindText}"
                                           Foreground="#F8FAFC"
                                           FontSize="16"
                                           FontWeight="Bold"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Center"
                                        Spacing="4">
                                <TextBlock Text="💧 Влажность"
                                           Foreground="#64748B"
                                           FontSize="12"/>
                                <TextBlock Text="{Binding HumidityText}"
                                           Foreground="#F8FAFC"
                                           FontSize="16"
                                           FontWeight="Bold"/>
                            </StackPanel>
                        
                   
                </Border >

                <!-- История -->
                <Border Background="#1E293B"
                        CornerRadius="16"
                        Padding="15">

                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="📋 История"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="#F8FAFC"/>
                            <Button Grid.Column="1"
                                    Command="{Binding ClearHistoryCommand}"
                                    Content="🗑️ Очистить"
                                    Background="#EF4444"
                                    Foreground="White"
                                    Padding="10,5"
                                    CornerRadius="8"
                                    FontSize="11"/>
                        </Grid>

                        <Border Height="1" Background="#334155"/>

                        <ListBox ItemsSource="{Binding HistoryItems}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MaxHeight="140">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#334155"
                                            CornerRadius="8"
                                            Margin="0,3"
                                            Padding="10,8">
                                        <TextBlock Text="{Binding}"
                                                   Foreground="#E2E8F0"
                                                   FontSize="12"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Город по умолчанию -->
                <Border Background="#1E293B"
                        CornerRadius="12"
                        Padding="12">
                    <TextBlock Text="{Binding DefaultCityText}"
                               Foreground="#64748B"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </Border>

        
      
    </Grid>
</Window>

