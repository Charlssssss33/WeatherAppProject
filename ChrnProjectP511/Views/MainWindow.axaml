<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ChrnProjectP511.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="ChrnProjectP511.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="ChrnProjectP511">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Styles>

    <Border Background="Blue">
        <StackPanel Margin="20" Spacing="15">

           
            <TextBlock Text="🌤️  Weather App" 
                       FontSize="28" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center"/>

           
            <Border Background="#16213E" 
                    CornerRadius="10" 
                    Padding="10">
                <StackPanel Spacing="10">
                    
                    
                    <TextBox x:Name="CityInput"
                             Watermark="Введите название города..."
                             Foreground="#FFFFFF"
                             Background="#0F3460"
                             BorderThickness="0"
                             Padding="10"
                             FontSize="16"/>
                    
                    
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SearchButton"
                                Content="🔍 Узнать погоду"
                                Background="#E94560"
                                Foreground="White"
                                FontWeight="Bold"
                                Padding="15,8"
                                HorizontalAlignment="Stretch"
                                Width="0"/>
                        
                        <Button x:Name="SaveDefaultButton"
                                Content="⭐ Запомнить"
                                Background="#533483"
                                Foreground="White"
                                Padding="15,8"
                                Width="0"/>
                    </StackPanel>
                    
                    
                    <TextBlock x:Name="LoadingText"
                               Text="⏳ Загрузка..."
                               Foreground="#FFA500"
                               HorizontalAlignment="Center"
                               IsVisible="False"/>
                    
                    
                    <TextBlock x:Name="ErrorText"
                               Text=""
                               Foreground="#E94560"
                               HorizontalAlignment="Center"
                               IsVisible="False"
                               FontSize="12"/>
                </StackPanel>
            </Border>

            
            <Border x:Name="WeatherCard"
                    Background="#16213E"
                    CornerRadius="15"
                    Padding="20"
                    IsVisible="False">
                
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    
                    
                    <TextBlock x:Name="CityNameText"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#FFFFFF"
 HorizontalAlignment="Center"/>
                    
                   
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Spacing="10">
                        <TextBlock x:Name="IconText"
                                   FontSize="64"/>
                        <TextBlock x:Name="TempText"
                                   FontSize="64"
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"/>
                    </StackPanel>
                    
                   
                    <TextBlock x:Name="DescriptionText"
                               FontSize="18"
                               Foreground="#BBBBBB"
                               HorizontalAlignment="Center"/>
                    
                   
                    <Border Height="1" Background="#333333" Margin="0,10"/>
                    
                    
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Spacing="30">
                        
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <TextBlock Text="💨  Ветер" 
                                       Foreground="#888888" 
                                       FontSize="12"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="WindText" 
                                       Foreground="#FFFFFF" 
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <TextBlock Text="💧  Влажность" 
                                       Foreground="#888888" 
                                       FontSize="12"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Name="HumidityText" 
                                       Foreground="#FFFFFF" 
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

           
            <Border Background="#16213E"
                    CornerRadius="10"
                    Padding="10">
                <StackPanel Spacing="8">
                    
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="📜  История запросов" 
                                   FontSize="16" 
                                   FontWeight="Bold"
                                   Foreground="#FFFFFF"/>
                        <Button x:Name="ClearHistoryButton"
                                Content="🗑️  Очистить"
                                Background="#533483"
                                Foreground="White"
                                Padding="10,5"
                                FontSize="12"
                                HorizontalAlignment="Right"
                                Width="0"/>
                    </StackPanel>
                    
                    <Border Height="1" Background="#333333"/>
                    
                    <ListBox x:Name="HistoryList"
                             Background="Transparent"
                             BorderThickness="0"
                             Height="150">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0F3460" 
                                        CornerRadius="5" 
                                        Margin="0,2" 
                                        Padding="8">
                                    <TextBlock Text="{Binding}" 
                                               Foreground="#EEEEEE"
                                               FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <TextBlock x:Name="HistoryEmptyText"
                               Text="Пока нет истории. Найдите город!"
                               Foreground="#888888"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               IsVisible="True"/>
                </StackPanel>
            </Border>

            
            <Border Background="#0F3460"
                    CornerRadius="8"
                    Padding="10">
                <TextBlock x:Name="DefaultCityText"
                           Text="⭐ Город по умолчанию: не выбран"
                           Foreground="#AAAAAA"
                           FontSize="11"
                           HorizontalAlignment="Center"/>
            </Border>

        </StackPanel>
    </Border>
</Window>
